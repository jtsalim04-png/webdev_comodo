###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_to_a_random_32_char_string
APP_URL=http://127.0.0.1:8000
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://127.0.0.1:8000
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Host machine / Symfony CLI (Docker app service overrides DATABASE_URL in docker-compose.yaml)
DATABASE_URL="mysql://Comodo_user:Comodo123@127.0.0.1:3308/ComodoDBNew?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> docker-compose/mysql (must match mysql service in docker-compose.yaml) ###
MYSQL_ROOT_PASSWORD=Comodo_Root_pass
MYSQL_DATABASE=ComodoDBNew
MYSQL_USER=Comodo_user
MYSQL_PASSWORD=Comodo123
MYSQL_PORT=3308
PMA_PORT=8081
APP_PORT=8000
###< docker-compose/mysql ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# dev: uses BREVO_SMTP_* below (config/packages/mailer.yaml when@dev)
# prod/Railway: uses BREVO_API_KEY (xkeysib-..., not xsmtpsib-)
MAILER_DSN=null://null
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
BREVO_API_KEY=
MAILER_FROM_ADDRESS=
MAILER_FROM_NAME="Comodo Booking"
DEV_TEST_EMAIL=
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase
###< lexik/jwt-authentication-bundle ###

###> Google OAuth ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
###< Google OAuth ###
