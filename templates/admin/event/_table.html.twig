<table class="admin-table datatable">
    <thead>
        <tr>
            <th>Title</th>
            <th>Date</th>
            <th>Location</th>
            <th>Price</th>
            <th>Organizer</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for event in events %}
        <tr>
            <td>{{ event.title }}</td>
            <td>{{ event.eventDate|date('M d, Y H:i') }}</td>
            <td>{{ event.location }}</td>
            <td>₱{{ event.price }}</td>
            <td>{{ event.organizer ? event.organizer.firstName ~ ' ' ~ event.organizer.lastName : 'N/A' }}</td>
            <td>
                <div class="action-buttons">
                    <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn-action btn-info" title="View details">
                        <i class="fas fa-eye"></i>
                    </a>
                    <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="btn-action btn-warning" title="Edit">
                        <i class="fas fa-edit"></i>
                    </a>
                    <form method="post" action="{{ path('app_event_delete', {'id': event.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this event? This action cannot be undone.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                        <button class="btn-action btn-delete" type="submit" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                    </form>
                </div>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="6" class="text-center py-4 text-muted">No events found</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
