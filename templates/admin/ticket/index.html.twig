{% extends 'admin/base_admin.html.twig' %}

{% block title %}Tickets{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="admin-page-header">
        <h1>Tickets / Sales</h1>
        <div class="admin-page-actions">
            <a href="{{ path('app_ticket_new') }}" class="btn btn-create">
                <i class="fas fa-plus me-2"></i>Create New Ticket
            </a>
        </div>
    </div>
    
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive admin-table-wrap">
                <table class="admin-table datatable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Event</th>
                            <th>Customer</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Purchase Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ticket in tickets %}
                        <tr>
                            <td>#{{ ticket.id }}</td>
                            <td>{{ ticket.event ? ticket.event.title : 'N/A' }}</td>
                            <td>{{ ticket.customer ? ticket.customer.firstName ~ ' ' ~ ticket.customer.lastName : 'N/A' }}</td>
                            <td>₱{{ ticket.price }}</td>
                            <td>
                                <span class="badge {% if ticket.status == 'confirmed' %}bg-success{% elseif ticket.status == 'cancelled' %}bg-danger{% else %}bg-warning{% endif %}">
                                    {{ ticket.status|title }}
                                </span>
                            </td>
                            <td>{{ ticket.purchaseDate ? ticket.purchaseDate|date('M d, Y H:i') : 'N/A' }}</td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('app_ticket_show', {'id': ticket.id}) }}" class="btn-action btn-info" title="View details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_ticket_edit', {'id': ticket.id}) }}" class="btn-action btn-warning" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">No tickets found</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

