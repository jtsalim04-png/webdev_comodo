{% extends 'admin/base_admin.html.twig' %}

{% block title %}Edit Ticket{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="admin-page-header">
        <h1>Edit Ticket</h1>
    </div>
    
    <div class="card">
        <div class="card-body pb-3">
            {% set eventAttr = form.event.vars.attr|merge({'class': (form.event.vars.attr.class|default('') ~ ' form-select')|trim}) %}
            {% set customerAttr = form.customer.vars.attr|merge({'class': (form.customer.vars.attr.class|default('') ~ ' form-select')|trim}) %}
            {% set priceAttr = form.price.vars.attr|merge({'class': (form.price.vars.attr.class|default('') ~ ' form-control')|trim}) %}
            {% set statusAttr = form.status.vars.attr|merge({'class': (form.status.vars.attr.class|default('') ~ ' form-select')|trim}) %}

            {{ form_start(form, {'attr': {'class': 'admin-form'}}) }}
                <div class="form-grid">
                    {{ form_row(form.event, {'attr': eventAttr}) }}
                    {{ form_row(form.customer, {'attr': customerAttr}) }}
                    {{ form_row(form.price, {'attr': priceAttr}) }}
                    {{ form_row(form.status, {'attr': statusAttr}) }}
                    <div class="mb-3">
                        <label class="form-label">Event Price</label>
                        <div id="event-price-display" class="form-control bg-light" style="font-weight: 600;">Select an event</div>
                    </div>
                </div>
                <div class="form-actions">
                    <a href="{{ path('app_ticket_index') }}" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const eventSelect = document.querySelector('select[name="ticket[event]"]');
            const priceDisplay = document.getElementById('event-price-display');
            const priceInput = document.querySelector('input[name="ticket[price]"]');

            function formatPrice(price) {
                if (price === null || price === undefined || price === '') {
                    return 'Select an event';
                }
                const number = parseFloat(price);
                if (Number.isNaN(number)) {
                    return 'Select an event';
                }
                return '₱' + number.toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            function updatePrice() {
                const option = eventSelect?.selectedOptions?.[0];
                const price = option ? option.getAttribute('data-price') : null;
                if (priceDisplay) {
                    priceDisplay.textContent = formatPrice(price);
                }
                if (priceInput && price !== null) {
                    priceInput.value = price;
                }
            }

            eventSelect?.addEventListener('change', updatePrice);
            updatePrice();
        });
    </script>
{% endblock %}

