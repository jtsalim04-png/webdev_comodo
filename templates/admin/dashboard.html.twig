{% extends 'admin/base_admin.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-dashboard-page {
            height: 100%;
            max-height: 100%;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 0.7rem;
            padding: 0.25rem 0 0;
        }
        .admin-dashboard-page .dashboard-stats { margin-bottom: 0; }
        .chart-grid {
            flex: 1 1 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 0.4rem;
            overflow: hidden;
            grid-auto-rows: minmax(0, 1fr);
        }
        .chart-card {
            height: 100%;
            min-height: 170px;
            display: flex;
            flex-direction: column;
        }
        .chart-card .card-body {
            flex: 1 1 auto;
            display: flex;
            flex-direction: column;
            padding: 0.45rem 0.45rem 0.35rem;
        }
        .chart-card canvas {
            flex: 1 1 auto;
            width: 100% !important;
            height: auto !important;
            max-height: 130px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container mt-0 admin-dashboard-page">
    <h1 class="mb-2">Admin Dashboard</h1>

    <!-- Statistics Cards -->
    <div id="admin-dashboard-live"
         data-controller="realtime-poll"
         data-realtime-poll-topic-value="admin_dashboard"
         data-realtime-poll-since-value="{{ realtime_version }}"
         data-realtime-mode="inner">
        {% include 'admin/_dashboard_content.html.twig' %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Scope overflow locking to dashboard only
        function lockDashboard() {
            document.documentElement.classList.add('dashboard-lock');
            document.body.classList.add('dashboard-lock');
            const main = document.querySelector('.admin-main');
            if (main) main.classList.add('dashboard-locked');
        }
        const roleChartData = {{ roleChartData|json_encode|raw }};
        const eventSalesChart = {{ eventSalesChart|json_encode|raw }};
        const palette = ['#f6a90c', '#f18f01', '#5c677d', '#5dade2', '#27ae60', '#9b59b6'];

        window.initAdminDashboardCharts = function initAdminDashboardCharts() {
            if (typeof Chart === 'undefined') {
                console.warn('Chart.js failed to load; charts not rendered.');
                return;
            }

            const dataEl = document.getElementById('admin-dashboard-chart-data');
            let roleData = roleChartData;
            let salesData = eventSalesChart;
            if (dataEl) {
                try {
                    const parsed = JSON.parse(dataEl.textContent || '{}');
                    roleData = parsed.roleChartData || roleData;
                    salesData = parsed.eventSalesChart || salesData;
                } catch (e) {
                    // keep server-rendered defaults
                }
            }

            const roleCtx = document.getElementById('roleChart');
            if (roleCtx) {
                Chart.getChart(roleCtx)?.destroy();
                new Chart(roleCtx, {
                    type: 'doughnut',
                    data: {
                        labels: roleData.labels,
                        datasets: [{
                            data: roleData.data,
                            backgroundColor: palette.slice(0, roleData.labels.length),
                            borderWidth: 1
                        }]
                    },
                    options: {
                        plugins: {
                            legend: { position: 'bottom' },
                            tooltip: { callbacks: { label: ctx => `${ctx.label}: ${ctx.formattedValue}` } }
                        }
                    }
                });
            }

            const eventCtx = document.getElementById('eventRevenueChart');
            if (eventCtx) {
                Chart.getChart(eventCtx)?.destroy();
                const labels = salesData.labels.length ? salesData.labels : ['No data'];
                const revenueData = salesData.revenue.length ? salesData.revenue : [0];
                const ticketData = salesData.tickets.length ? salesData.tickets : [0];

                new Chart(eventCtx, {
                    type: 'bar',
                    data: {
                        labels,
                        datasets: [
                            {
                                label: 'Revenue',
                                data: revenueData,
                                backgroundColor: palette[0],
                                yAxisID: 'y'
                            },
                            {
                                label: 'Tickets Sold',
                                data: ticketData,
                                backgroundColor: palette[2],
                                yAxisID: 'y1'
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        interaction: { mode: 'index', intersect: false },
                        scales: {
                            y: {
                                type: 'linear',
                                position: 'left',
                                beginAtZero: true,
                                title: { display: true, text: 'Revenue' }
                            },
                            y1: {
                                type: 'linear',
                                position: 'right',
                                beginAtZero: true,
                                grid: { drawOnChartArea: false },
                                title: { display: true, text: 'Tickets' }
                            }
                        },
                        plugins: {
                            legend: { position: 'bottom' },
                            tooltip: {
                                callbacks: {
                                    label: ctx => {
                                        const label = ctx.dataset.label || '';
                                        const value = ctx.formattedValue;
                                        return label === 'Revenue' ? `${label}: ₱${value}` : `${label}: ${value}`;
                                    }
                                }
                            }
                        }
                    }
                });
            }
        };

        document.addEventListener('DOMContentLoaded', window.initAdminDashboardCharts);
        document.addEventListener('turbo:load', window.initAdminDashboardCharts);
        document.addEventListener('realtime:updated', function (event) {
            if (event.detail?.topic === 'admin_dashboard') {
                window.initAdminDashboardCharts();
            }
        });
    </script>
{% endblock %}

