<table class="admin-table datatable">
    <thead>
        <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Name</th>
            <th>Role</th>
            <th>Status</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for user in users %}
        <tr>
            <td class="text-muted">#{{ user.id }}</td>
            <td>{{ user.email }}</td>
            <td>{{ user.firstName }} {{ user.lastName }}</td>
            <td>
                <span class="badge {{ user.role == 'ROLE_ADMIN' ? 'bg-danger' : (user.role == 'ROLE_ORGANIZER' ? 'bg-info' : 'bg-primary') }}">
                    {% if user.role == 'ROLE_USER' %}User{% else %}{{ user.role|replace({'ROLE_': ''})|title }}{% endif %}
                </span>
            </td>
            <td>
                <span class="badge {% if user.isActive %}bg-success{% else %}bg-danger{% endif %}">
                    {{ user.isActive ? 'Active' : 'Inactive' }}
                </span>
            </td>
            <td>{{ user.createdAt ? user.createdAt|date('M d, Y H:i') : '' }}</td>
            <td>
                <div class="action-buttons">
                    {% if user.role == 'ROLE_USER' %}
                    <button type="button"
                            class="btn-action btn-info"
                            data-open-order
                            data-user-id="{{ user.id }}"
                            data-user-name="{{ user.firstName }} {{ user.lastName }}"
                            aria-label="Start order"
                            title="Start an order for this user">
                        <i class="fas fa-shopping-cart" aria-hidden="true"></i>
                    </button>
                    {% endif %}
                    <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn-action" title="View details">
                        <i class="fas fa-eye" aria-hidden="true"></i>
                    </a>
                    <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn-action" title="Edit user">
                        <i class="fas fa-pen-square" aria-hidden="true"></i>
                    </a>
                    {% if app.user.id != user.id %}
                    <form action="{{ path('app_user_toggle_status', {'id': user.id}) }}" method="post" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_status' ~ user.id) }}">
                        <button type="submit"
                                class="btn-action {% if user.isActive %}btn-warning{% else %}btn-success{% endif %}"
                                title="{% if user.isActive %}Disable{% else %}Enable{% endif %} user"
                                onclick="return confirm('Are you sure you want to {% if user.isActive %}disable{% else %}enable{% endif %} this user?');">
                            <i class="fas fa-{% if user.isActive %}ban{% else %}check{% endif %}" aria-hidden="true"></i>
                        </button>
                    </form>
                    <form action="{{ path('app_user_reset_password', {'id': user.id}) }}" method="post" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('reset_password' ~ user.id) }}">
                        <button type="submit" class="btn-action btn-info" title="Reset password"
                                onclick="return confirm('Are you sure you want to reset this user\'s password?');">
                            <i class="fas fa-key" aria-hidden="true"></i>
                        </button>
                    </form>
                    <form action="{{ path('app_user_delete', {'id': user.id}) }}" method="post" class="d-inline"
                          onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button type="submit" class="btn-action btn-delete" title="Delete user">
                            <i class="fas fa-trash" aria-hidden="true"></i>
                        </button>
                    </form>
                    {% endif %}
                </div>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="7" class="text-center py-4 text-muted">No users found</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
