{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block body_class %}tarot-bg-page{% endblock %}

{% block body %}
    <div class="user-dashboard">
        <div class="user-dashboard__header">
            <h1>Welcome{{ app.user and app.user.firstName ? ', ' ~ app.user.firstName : '' }}</h1>
            <p>Browse upcoming events and book your ticket.</p>
        </div>

        <section class="events-carousel" aria-label="Upcoming events">
            <div class="events-carousel__top">
                <h2>Available Events</h2>
                <div class="events-carousel__controls">
                    <button class="events-carousel__btn" type="button" data-carousel-prev aria-label="Previous events">‹</button>
                    <button class="events-carousel__btn" type="button" data-carousel-next aria-label="Next events">›</button>
                </div>
            </div>

            <div id="user-dashboard-live"
                 data-controller="realtime-poll"
                 data-realtime-poll-topic-value="user_dashboard"
                 data-realtime-poll-since-value="{{ realtime_version }}"
                 data-realtime-mode="inner">
            {% if events is empty %}
                <div class="events-carousel__empty">
                    <p>No upcoming events yet. Please check back soon.</p>
                    <a class="cta-button" href="{{ path('order_list') }}">View all events</a>
                </div>
            {% else %}
                <div class="events-carousel__track" data-carousel-track tabindex="0">
                    {% for event in events %}
                        <article class="event-card">
                            <img src="{{ asset('images/event-default.svg') }}" alt="{{ event.title }} image" class="event-card__image">
                            <h3 class="event-card__title">{{ event.title }}</h3>
                                {% if event.description %}
                                    <p class="event-card__excerpt">{{ event.description|length > 110 ? event.description|slice(0, 110) ~ '…' : event.description }}</p>
                                {% endif %}
                            <div class="event-card__meta">
                                <div class="event-card__meta-row">
                                    <span class="event-card__label">Date &amp; time</span>
                                    <span class="event-card__value">
                                        {{ event.eventDate ? event.eventDate|date('M d, Y g:i A') : 'TBD' }}
                                    </span>
                                </div>
                                    <div class="event-card__meta-row">
                                        <span class="event-card__label">Price</span>
                                        <span class="event-card__value">₱{{ event.price|number_format(2, '.', ',') }}</span>
                                    </div>
                                {% if event.location %}
                                    <div class="event-card__meta-row">
                                        <span class="event-card__label">Location</span>
                                        <span class="event-card__value">{{ event.location }}</span>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="event-card__actions">
                                <a class="event-card__primary" href="{{ path('order_show', { id: event.id }) }}">Book now</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
            </div>
        </section>
    </div>

    <script>
        function initEventsCarousel() {
            const track = document.querySelector('[data-carousel-track]');
            if (!track) return;

            const prev = document.querySelector('[data-carousel-prev]');
            const next = document.querySelector('[data-carousel-next]');

            const getScrollAmount = () => {
                const firstCard = track.querySelector('.event-card');
                if (!firstCard) return 320;
                const styles = window.getComputedStyle(track);
                const gap = parseFloat(styles.columnGap || styles.gap || '16') || 16;
                return firstCard.getBoundingClientRect().width + gap;
            };

            const scrollByCards = (dir) => {
                track.scrollBy({ left: dir * getScrollAmount(), behavior: 'smooth' });
            };

            if (prev && !prev.dataset.carouselBound) {
                prev.dataset.carouselBound = '1';
                prev.addEventListener('click', () => scrollByCards(-1));
            }
            if (next && !next.dataset.carouselBound) {
                next.dataset.carouselBound = '1';
                next.addEventListener('click', () => scrollByCards(1));
            }

            if (!track.dataset.carouselBound) {
                track.dataset.carouselBound = '1';
                track.addEventListener('keydown', (e) => {
                    if (e.key === 'ArrowLeft') scrollByCards(-1);
                    if (e.key === 'ArrowRight') scrollByCards(1);
                });
            }
        }

        document.addEventListener('DOMContentLoaded', initEventsCarousel);
        document.addEventListener('realtime:updated', function (event) {
            if (event.detail?.topic === 'user_dashboard') {
                initEventsCarousel();
            }
        });
    </script>
{% endblock %}

