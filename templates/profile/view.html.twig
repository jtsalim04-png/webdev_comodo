{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}
{% block body_class %}black-bg-page{% endblock %}

{% block body %}
<div class="container mt-5">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="row justify-content-center profile-grid">
        <div class="col-md-4">
            <div class="card profile-card profile-summary">
                <div class="card-header">
                    <h2 class="mb-0">Profile Summary</h2>
                </div>
                <div class="card-body text-center">
                    <div class="profile-avatar">{{ user.firstName|slice(0,1) ~ user.lastName|slice(0,1) }}</div>
                    <h3 class="profile-name">{{ user.firstName }} {{ user.lastName }}</h3>
                    <p class="profile-email">{{ user.email }}</p>

                    <div class="profile-badges">
                        <span class="badge {% if user.role == 'ROLE_ADMIN' %}bg-danger{% elseif user.role == 'ROLE_ORGANIZER' %}bg-info{% else %}bg-secondary{% endif %}">
                            {{ user.role|replace({'ROLE_': ''})|title }}
                        </span>
                        <span class="badge {% if user.isVerified %}bg-success{% else %}bg-warning text-dark{% endif %}">
                            {{ user.isVerified ? 'Verified' : 'Unverified' }}
                        </span>
                    </div>

                    <div class="profile-status-grid">
                        <div>
                            <small class="text-muted">Joined</small>
                            <div>{{ user.createdAt ? user.createdAt|date('M d, Y') : 'N/A' }}</div>
                        </div>
                        <div>
                            <small class="text-muted">Status</small>
                            <div class="badge {% if user.isActive %}bg-success{% else %}bg-danger{% endif %}">
                                {{ user.isActive ? 'Active' : 'Inactive' }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card profile-card profile-details-card">
                <div class="card-header">
                    <h2 class="mb-0">Account Details</h2>
                </div>
                <div class="card-body">
                    <div class="profile-detail-row">
                        <span>Name</span>
                        <strong>{{ user.firstName }} {{ user.lastName }}</strong>
                    </div>
                    <div class="profile-detail-row">
                        <span>Email</span>
                        <strong>{{ user.email }}</strong>
                    </div>
                    <div class="profile-detail-row">
                        <span>Role</span>
                        <strong>{{ user.role|replace({'ROLE_': ''})|title }}</strong>
                    </div>
                    <div class="profile-detail-row">
                        <span>Account created</span>
                        <strong>{{ user.createdAt ? user.createdAt|date('F d, Y') : 'N/A' }}</strong>
                    </div>
                    <div class="profile-detail-row">
                        <span>Account status</span>
                        <strong>{{ user.isActive ? 'Active' : 'Inactive' }}</strong>
                    </div>

                    <div class="profile-actions">
                        <a href="{{ path('app_profile_change_password') }}" class="btn btn-primary btn-block">Change Password</a>
                        <a href="{{ path('order_list') }}" class="btn btn-secondary btn-block">Browse Events</a>
                        <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary btn-block">Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

