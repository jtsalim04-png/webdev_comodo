{% extends 'base.html.twig' %}

{% block title %}Change Password{% endblock %}
{% block body_class %}black-bg-page{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card profile-card">
                <div class="card-header">
                    <h2 class="mb-0">Change Password</h2>
                </div>
                <div class="card-body">
                    {% if error %}
                        <div class="alert alert-danger">{{ error }}</div>
                    {% endif %}

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success">{{ message }}</div>
                    {% endfor %}

                    <p class="text-muted mb-4">Use a strong password and avoid reusing credentials from other sites.</p>

                    <form method="POST" action="{{ path('app_profile_change_password') }}">
                        <div class="mb-3">
                            <label for="current_password" class="form-label">Current Password</label>
                            <input type="password" class="form-control" id="current_password" name="current_password" required>
                        </div>

                        <div class="mb-3">
                            <label for="new_password" class="form-label">New Password</label>
                            <input type="password" class="form-control" id="new_password" name="new_password" required minlength="6" aria-describedby="password_help">
                            <small id="password_help" class="form-text text-danger">Password must be at least 6 characters long.</small>
                        </div>

                        <div class="mb-3">
                            <label for="confirm_password" class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" id="confirm_password" name="confirm_password" required minlength="6">
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Change Password</button>
                            <a href="{{ path('app_profile') }}" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const passwordInput = document.getElementById('new_password');
            const helpText = document.getElementById('password_help');
            if (!passwordInput || !helpText) return;

            const minLength = 6;
            const updateState = () => {
                const value = passwordInput.value || '';
                const meetsLength = value.length >= minLength;
                helpText.textContent = meetsLength
                    ? 'Password meets the minimum length.'
                    : `Password must be at least ${minLength} characters long.`;
                helpText.classList.toggle('text-success', meetsLength);
                helpText.classList.toggle('text-danger', !meetsLength);
            };

            passwordInput.addEventListener('input', updateState);
            updateState();
        });
    </script>
{% endblock %}

