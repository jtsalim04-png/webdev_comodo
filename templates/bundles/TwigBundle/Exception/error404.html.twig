{% extends 'base.html.twig' %}

{% block title %}Page Not Found{% endblock %}

{% block body %}
<div class="container py-5" style="margin-top: 80px;">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-body p-5 text-center">
                    <div class="display-4 mb-3" style="color: var(--butterscotch-mousse);">
                        <i class="fas fa-compass"></i>
                    </div>
                    <h1 class="mb-3">404 — Page Not Found</h1>
                    <p class="text-muted mb-4">
                        The page you’re looking for may have been moved, renamed, or no longer exists.
                        Try heading back home or using the navigation to find what you need.
                    </p>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_dashboard') }}" class="btn btn-primary">Go to Admin Dashboard</a>
                        {% elseif is_granted('ROLE_ORGANIZER') %}
                            <a href="{{ path('organizer_dashboard') }}" class="btn btn-primary">Go to Organizer Dashboard</a>
                        {% elseif is_granted('ROLE_USER') %}
                            <a href="{{ path('home') }}" class="btn btn-primary">Go to Home</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-primary">Login</a>
                        {% endif %}
                        <a href="{{ path('home') }}" class="btn btn-secondary">Back to Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}


