{% extends 'base.html.twig' %}

{% block title %}Log In - Comodo Booking{% endblock %}

{% block body_class %}login-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body.login-page {
            background:
                linear-gradient(180deg, rgba(219, 216, 204, 0.78) 0%, rgba(200, 196, 183, 0.82) 100%),
                url("{{ asset('images/Star Tarot.png') }}") center / cover no-repeat !important;
            min-height: 100vh;
        }
    </style>
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="login-card">
        <div class="login-logo">
            <img src="{{ asset('images/Comodo Booking Logo.png') }}" alt="Comodo Booking" class="img-fluid">
        </div>
        
        <form method="post" action="{{ path('app_login') }}" class="login-form">
            {% if error %}
                <div class="alert alert-danger">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3 text-center">
                    You are logged in as {{ app.user.userIdentifier }}<br>
                    <a href="{{ path('app_logout') }}">Logout</a>
                </div>
            {% endif %}

            <h1 class="login-title">Welcome Back</h1>
            
            <div class="form-group">
                <label for="inputEmail">Email or username</label>
                <input type="text"
                       value="{{ last_username }}"
                       name="email"
                       id="inputEmail"
                       class="form-control"
                       placeholder="Email address (admins may enter &quot;admin&quot;)"
                       autocomplete="username"
                       required
                       autofocus>
            </div>

            <div class="form-group">
                <label for="inputPassword">Password</label>
                <input type="password" 
                       name="password" 
                       id="inputPassword" 
                       class="form-control" 
                       placeholder="Enter your password" 
                       required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group form-check align-items-center d-flex gap-2">
                <input type="checkbox" class="form-check-input" id="remember_me" name="_remember_me">
                <label class="form-check-label mb-0" for="remember_me">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Sign In</button>
            <a href="{{ path('connect_google_start') }}" class="btn btn-secondary btn-block mt-2">Sign in with Google</a>
        </form>

        {% set pendingEmail = app.session.get('pending_verification_email') %}
        {% if pendingEmail %}
            <form method="post" action="{{ path('app_resend_verification') }}" class="mt-3 text-center">
                <input type="hidden" name="_token" value="{{ csrf_token('resend_verification') }}">
                <input type="hidden" name="email" value="{{ pendingEmail }}">
                <button type="submit" class="btn btn-secondary btn-block">
                    Resend verification email
                </button>
                <div class="mt-2" style="font-size: 0.95rem; opacity: 0.85;">
                    Sent to <strong>{{ pendingEmail }}</strong>
                </div>
            </form>
        {% endif %}

        <div class="login-footer">
            <p>Don't have an account? <a href="{{ path('app_register') }}">Register here</a></p>
        </div>
    </div>
</div>
{% endblock %}

