{% extends 'base.html.twig' %}

{% block title %}Comodo Booking | Landing Page{% endblock %}
{% block body_class %}tarot-bg-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ================================
           Tarot-Inspired Landing Page
           HTML/CSS only – respects existing palette
           ================================ */
        .lp {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1rem 4.5rem;
        }

        .lp-card {
            background: #fffefc;
            border: 1px solid rgba(34, 34, 33, 0.12);
            border-radius: 18px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        }

        .lp-section {
            margin-top: 1.25rem;
            padding: 1.25rem;
        }

        .lp-hero {
            position: relative;
            overflow: hidden;
            padding: 2.25rem 1.25rem 1.25rem;
            border-radius: 22px;
            background:
                radial-gradient(circle at 20% 30%, rgba(169, 129, 82, 0.20) 0%, transparent 60%),
                radial-gradient(circle at 80% 20%, rgba(34, 34, 33, 0.08) 0%, transparent 55%),
                linear-gradient(180deg, #fffefc 0%, #f6f3ed 100%);
        }

        .lp-hero::before {
            content: "";
            position: absolute;
            inset: -20px;
            background-image: url("{{ asset('images/Star Tarot.png') }}");
            background-size: cover;
            background-position: center;
            opacity: 0.10;
            pointer-events: none;
        }

        .lp-hero__inner {
            position: relative;
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 1.25rem;
            align-items: center;
        }

        .lp-kicker {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.35rem 0.75rem;
            border-radius: 999px;
            border: 1px solid rgba(169, 129, 82, 0.35);
            background: rgba(219, 216, 204, 0.35);
            color: var(--tuatara);
            font-weight: 600;
            letter-spacing: 0.03em;
            font-size: 0.9rem;
        }

        .lp-kicker::before {
            content: "";
            width: 22px;
            height: 22px;
            border-radius: 7px;
            background-image: url("{{ asset('images/tarot flower.png') }}");
            background-size: cover;
            background-position: center;
            border: 1px solid rgba(34, 34, 33, 0.10);
        }

        .lp-title {
            margin: 0.75rem 0 0.5rem;
            font-size: clamp(2rem, 4.4vw, 3.25rem);
            line-height: 1.08;
            color: var(--tuatara);
        }

        .lp-subtitle {
            margin: 0 0 1rem;
            max-width: 56ch;
            color: rgba(34, 34, 33, 0.8);
            font-size: 1.05rem;
            line-height: 1.65;
        }

        .lp-actions {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .lp-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 44px;
            min-height: 44px;
            padding: 0.8rem 1.2rem;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 700;
            font-family: 'EB Garamond', serif;
            letter-spacing: 0.02em;
            border: 1px solid transparent;
            transition: transform 0.12s ease, background-color 0.18s ease, border-color 0.18s ease;
            cursor: pointer;
        }

        .lp-btn--primary {
            background: var(--butterscotch-mousse);
            color: var(--timberwolf);
        }

        .lp-btn--primary:hover {
            background: var(--butterscotch-dark);
            transform: translateY(-1px);
        }

        .lp-btn--ghost {
            background: rgba(219, 216, 204, 0.35);
            border-color: rgba(34, 34, 33, 0.14);
            color: var(--tuatara);
        }

        .lp-btn--ghost:hover {
            transform: translateY(-1px);
            border-color: rgba(169, 129, 82, 0.45);
        }

        .lp-hero__panel {
            position: relative;
            border-radius: 18px;
            padding: 1rem;
            background:
                linear-gradient(180deg, rgba(34, 34, 33, 0.90) 0%, rgba(34, 34, 33, 0.98) 100%);
            color: var(--timberwolf);
            border: 1px solid rgba(169, 129, 82, 0.35);
            overflow: hidden;
        }

        .lp-hero__panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: url("{{ asset('images/gld cloud no line.png') }}");
            background-size: 260px auto;
            background-repeat: no-repeat;
            background-position: right -40px bottom -60px;
            opacity: 0.22;
            pointer-events: none;
        }

        .lp-hero__panel > * { position: relative; }

        .lp-panel-title {
            margin: 0 0 0.25rem;
            color: var(--butterscotch-mousse);
            font-size: 1.25rem;
        }

        .lp-panel-text {
            margin: 0 0 0.85rem;
            color: rgba(219, 216, 204, 0.88);
            font-size: 0.98rem;
            line-height: 1.55;
        }

        .lp-panel-list {
            margin: 0;
            padding-left: 1.1rem;
            color: rgba(219, 216, 204, 0.92);
        }

        .lp-panel-list li { margin: 0.35rem 0; }

        .lp-grid {
            display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            gap: 1rem;
        }

        .lp-col-4 { grid-column: span 4; }
        .lp-col-6 { grid-column: span 6; }
        .lp-col-12 { grid-column: span 12; }

        .lp-h2 {
            margin: 0 0 0.75rem;
            font-size: 1.8rem;
        }

        .lp-muted { color: rgba(34, 34, 33, 0.75); }

        .lp-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.4rem 0.75rem;
            border-radius: 999px;
            background: rgba(169, 129, 82, 0.12);
            border: 1px solid rgba(169, 129, 82, 0.25);
            font-weight: 700;
        }

        .lp-feature {
            padding: 1rem;
            border-radius: 16px;
            border: 1px solid rgba(34, 34, 33, 0.10);
            background: #ffffff;
        }

        .lp-feature h3 {
            margin: 0 0 0.35rem;
            font-size: 1.25rem;
        }

        .lp-feature p { margin: 0; color: rgba(34, 34, 33, 0.78); }

        .lp-event-card {
            padding: 1rem;
            border-radius: 16px;
            border: 1px solid rgba(34, 34, 33, 0.10);
            background: #ffffff;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
            min-height: 180px;
        }

        .lp-event-card__meta {
            display: grid;
            gap: 0.35rem;
            color: rgba(34, 34, 33, 0.8);
            font-size: 0.98rem;
        }

        .lp-event-card__title {
            margin: 0;
            font-size: 1.35rem;
        }

        .lp-event-card__row {
            display: flex;
            justify-content: space-between;
            gap: 0.75rem;
        }

        .lp-event-card__label {
            color: rgba(34, 34, 33, 0.65);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            font-size: 0.8rem;
        }

        .lp-event-card__value {
            font-weight: 600;
            text-align: right;
        }

        .lp-event-card__actions {
            margin-top: auto;
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .lp-step {
            display: flex;
            gap: 0.85rem;
            align-items: flex-start;
            padding: 1rem;
            border-radius: 16px;
            border: 1px solid rgba(34, 34, 33, 0.10);
            background: #ffffff;
        }

        .lp-step__num {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            background: var(--tuatara);
            color: var(--timberwolf);
            font-weight: 800;
            flex: 0 0 auto;
        }

        .lp-step h3 { margin: 0 0 0.25rem; }
        .lp-step p { margin: 0; color: rgba(34, 34, 33, 0.78); }

        .lp-quote {
            padding: 1rem;
            border-radius: 16px;
            border: 1px solid rgba(34, 34, 33, 0.10);
            background: #ffffff;
        }

        .lp-quote p { margin: 0 0 0.65rem; color: rgba(34, 34, 33, 0.82); }
        .lp-quote cite { font-style: normal; font-weight: 800; color: var(--tuatara); }

        .lp-cta {
            position: relative;
            overflow: hidden;
            padding: 1.25rem;
            border-radius: 18px;
            background: linear-gradient(180deg, rgba(34, 34, 33, 0.92) 0%, rgba(34, 34, 33, 0.98) 100%);
            border: 1px solid rgba(169, 129, 82, 0.35);
            color: var(--timberwolf);
        }

        .lp-cta::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: url("{{ asset('images/wht cloud no line.png') }}");
            background-size: 340px auto;
            background-repeat: no-repeat;
            background-position: left -60px bottom -90px;
            opacity: 0.20;
            pointer-events: none;
        }

        .lp-cta > * { position: relative; }

        .lp-cta h2 { margin: 0 0 0.35rem; color: var(--butterscotch-mousse); }
        .lp-cta p { margin: 0 0 1rem; color: rgba(219, 216, 204, 0.90); }

        .lp-cta__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

        /* Responsive */
        @media (max-width: 980px) {
            .lp-hero__inner {
                grid-template-columns: 1fr;
            }
            .lp-col-6 { grid-column: span 12; }
            .lp-col-4 { grid-column: span 6; }
        }

        @media (max-width: 640px) {
            .lp {
                padding: 1.25rem 0.9rem 3.5rem;
            }
            .lp-section {
                padding: 1rem;
            }
            .lp-col-4 { grid-column: span 12; }
            .lp-btn { width: 100%; }
            .lp-actions { gap: 0.6rem; }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="lp" aria-label="Comodo Booking landing page">
        <!-- Section 1: Hero -->
        <header class="lp-hero lp-card">
            <div class="lp-hero__inner">
                <div>
                    {# <div class="lp-kicker">Tarot-inspired event booking</div> #}
                    <h1 class="lp-title">Find your next experience  written in the stars.</h1>
                    <p class="lp-subtitle">
                        Comodo Booking brings a calm, guided flow to discovering events, reserving tickets, and checking in.
                        For organizers, it keeps event management clean and dependable.
                    </p>
                    <div class="lp-actions">
                        <a class="lp-btn lp-btn--primary" href="{{ path('app_register') }}">Create your account</a>
                        <a class="lp-btn lp-btn--ghost" href="{{ path('app_login') }}">Sign in</a>
                    </div>
                </div>
                <aside class="lp-hero__panel" aria-label="Quick highlights">
                    <h2 class="lp-panel-title">What you can do</h2>
                    <p class="lp-panel-text">A simple platform for attendees and organizers.</p>
                    <ul class="lp-panel-list">
                        <li>Browse and view event details</li>
                        <li>Purchase tickets and track your orders</li>
                        <li>Organizers can create events and manage listings</li>
                        <li>Secure check-in with ticket validation</li>
                    </ul>
                </aside>
            </div>
        </header>

        <!-- Section 2: Featured events (static preview) -->
        <section class="lp-section lp-card" aria-label="Featured events">
            <div class="lp-grid">
                <div class="lp-col-12">
                    <h2 class="lp-h2">Featured Picks</h2>
                    <p class="lp-muted">A preview of what an event card looks like. Full listings appear after login.</p>
                </div>

                <article class="lp-event-card lp-col-4">
                    <span class="lp-pill">The Lovers • Social</span>
                    <h3 class="lp-event-card__title">Moonlit Mixer</h3>
                    <div class="lp-event-card__meta">
                        <div class="lp-event-card__row">
                            <span class="lp-event-card__label">When</span>
                            <span class="lp-event-card__value">Fri 7:00 PM</span>
                        </div>
                        <div class="lp-event-card__row">
                            <span class="lp-event-card__label">Where</span>
                            <span class="lp-event-card__value">Comodo Hall</span>
                        </div>
                    </div>
                    <div class="lp-event-card__actions">
                        <a class="lp-btn lp-btn--primary" href="{{ path('app_register') }}">Book a seat</a>
                        <a class="lp-btn lp-btn--ghost" href="{{ path('about_us') }}">Learn more</a>
                    </div>
                </article>

                <article class="lp-event-card lp-col-4">
                    <span class="lp-pill">The Chariot • Live</span>
                    <h3 class="lp-event-card__title">Starlight Concert</h3>
                    <div class="lp-event-card__meta">
                        <div class="lp-event-card__row">
                            <span class="lp-event-card__label">When</span>
                            <span class="lp-event-card__value">Sat 8:30 PM</span>
                        </div>
                        <div class="lp-event-card__row">
                            <span class="lp-event-card__label">Where</span>
                            <span class="lp-event-card__value">Aurora Arena</span>
                        </div>
                    </div>
                    <div class="lp-event-card__actions">
                        <a class="lp-btn lp-btn--primary" href="{{ path('app_register') }}">Reserve ticket</a>
                        <a class="lp-btn lp-btn--ghost" href="{{ path('contact_us') }}">Ask a question</a>
                    </div>
                </article>

                <article class="lp-event-card lp-col-4">
                    <span class="lp-pill">The Magician • Workshop</span>
                    <h3 class="lp-event-card__title">Creative Craft Night</h3>
                    <div class="lp-event-card__meta">
                        <div class="lp-event-card__row">
                            <span class="lp-event-card__label">When</span>
                            <span class="lp-event-card__value">Sun 4:00 PM</span>
                        </div>
                        <div class="lp-event-card__row">
                            <span class="lp-event-card__label">Where</span>
                            <span class="lp-event-card__value">Studio 3</span>
                        </div>
                    </div>
                    <div class="lp-event-card__actions">
                        <a class="lp-btn lp-btn--primary" href="{{ path('app_register') }}">Join now</a>
                        <a class="lp-btn lp-btn--ghost" href="{{ path('about_us') }}">How it works</a>
                    </div>
                </article>
            </div>
        </section>

        <!-- Section 3: How it works -->
        <section class="lp-section lp-card" aria-label="How it works">
            <div class="lp-grid">
                <div class="lp-col-12">
                    <h2 class="lp-h2">How it works</h2>
                    <p class="lp-muted">A guided flow—simple for attendees, powerful for organizers.</p>
                </div>

                <div class="lp-step lp-col-4">
                    <div class="lp-step__num">1</div>
                    <div>
                        <h3>Pick an event</h3>
                        <p>Browse listings and open event details to confirm date, location, and price.</p>
                    </div>
                </div>

                <div class="lp-step lp-col-4">
                    <div class="lp-step__num">2</div>
                    <div>
                        <h3>Book your ticket</h3>
                        <p>Reserve a ticket in a clear checkout flow. Your purchase is recorded instantly.</p>
                    </div>
                </div>

                <div class="lp-step lp-col-4">
                    <div class="lp-step__num">3</div>
                    <div>
                        <h3>Arrive with confidence</h3>
                        <p>Use your ticket for entry with consistent validation and account verification.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 4: Categories -->
        <section class="lp-section lp-card" aria-label="Event categories">
            <div class="lp-grid">
                <div class="lp-col-12">
                    <h2 class="lp-h2">Explore by category</h2>
                    <p class="lp-muted">Find the vibe that matches your card pull.</p>
                </div>

                <article class="lp-feature lp-col-6">
                    <h3>Concerts & Live Shows</h3>
                    <p>High energy nights—from indie sets to full-stage productions.</p>
                </article>
                <article class="lp-feature lp-col-6">
                    <h3>Workshops & Classes</h3>
                    <p>Hands-on sessions for learning, making, and meeting new people.</p>
                </article>
                <article class="lp-feature lp-col-6">
                    <h3>Community Events</h3>
                    <p>Markets, meetups, and gatherings built around shared interests.</p>
                </article>
                <article class="lp-feature lp-col-6">
                    <h3>Special Nights</h3>
                    <p>Limited-seat experiences—curated, themed, and unforgettable.</p>
                </article>
            </div>
        </section>

        <!-- Section 5: Testimonials -->
        <section class="lp-section lp-card" aria-label="Testimonials">
            <div class="lp-grid">
                <div class="lp-col-12">
                    <h2 class="lp-h2">Reviews from the community</h2>
                    <p class="lp-muted">What people say after booking with Comodo.</p>
                </div>
                <blockquote class="lp-quote lp-col-4">
                    <p>“The checkout flow was smooth and the ticket was ready instantly. Clean and easy.”</p>
                    <cite>— Attendee</cite>
                </blockquote>
                <blockquote class="lp-quote lp-col-4">
                    <p>“Event management feels organized. I can track events and tickets without the clutter.”</p>
                    <cite>— Organizer</cite>
                </blockquote>
                <blockquote class="lp-quote lp-col-4">
                    <p>“The UI looks premium, and everything is consistent between web and API.”</p>
                    <cite>— Admin</cite>
                </blockquote>
            </div>
        </section>

        <!-- Section 6: Final CTA -->
        <section class="lp-cta" aria-label="Get started call to action">
            <h2>Ready to book your next event?</h2>
            <p>Create an account to start browsing and reserving tickets. Organizers can create events right after signup.</p>
            <div class="lp-cta__actions">
                <a class="lp-btn lp-btn--primary" href="{{ path('app_register') }}">Get started</a>
                <a class="lp-btn lp-btn--ghost" href="{{ path('contact_us') }}">Contact us</a>
            </div>
        </section>
    </main>
{% endblock %}
