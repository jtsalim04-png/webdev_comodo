{% extends 'base.html.twig' %}

{% block title %}Order Tickets{% endblock %}
{% block body_class %}tarot-bg-page{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Order Tickets</h1>
    </div>
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive admin-table-wrap">
                {% if events|length > 0 %}
                    <table class="admin-table datatable">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Location</th>
                                <th>Price</th>
                                <th>Organizer</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for event in events %}
                            <tr>
                                <td>{{ event.title }}</td>
                                <td>{{ event.eventDate ? event.eventDate|date('M d, Y H:i') : 'TBD' }}</td>
                                <td>{{ event.location ?: 'TBD' }}</td>
                                <td>₱{{ event.price|number_format(2, '.', ',') }}</td>
                                <td>{{ event.organizer ? event.organizer.firstName ~ ' ' ~ event.organizer.lastName : 'N/A' }}</td>
                                <td>
                                    <a href="{{ path('order_show', {'id': event.id}) }}" class="btn btn-sm btn-primary">View</a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="p-4 text-muted">No events available yet.</div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

