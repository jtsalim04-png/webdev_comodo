{% extends 'base.html.twig' %}

{% block title %}My Events{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">My Events</h1>
        <a href="{{ path('organizer_events_new') }}" class="btn btn-create">
            <i class="fas fa-plus me-2"></i>Create New Event
        </a>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive admin-table-wrap">
                {% if events|length > 0 %}
                    <table class="admin-table datatable">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Location</th>
                                <th>Price</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for event in events %}
                            <tr>
                                <td>{{ event.title }}</td>
                                <td>{{ event.eventDate|date('M d, Y H:i') }}</td>
                                <td>{{ event.location }}</td>
                                <td>₱{{ event.price }}</td>
                                <td>
                                    <div class="action-buttons">
                                        <a href="{{ path('organizer_events_show', {'id': event.id}) }}" class="btn-action btn-info" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('organizer_events_edit', {'id': event.id}) }}" class="btn-action btn-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="{{ path('organizer_events_delete', {'id': event.id}) }}" class="d-inline" onsubmit="return confirm('Delete this event? This cannot be undone.');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                            <button class="btn-action btn-delete" type="submit" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="p-4 text-muted">No events yet. <a href="{{ path('organizer_events_new') }}">Create your first event</a></div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

