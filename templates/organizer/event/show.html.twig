{% extends 'base.html.twig' %}

{% block title %}Event Details{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">{{ event.title }}</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('organizer_events_list') }}" class="btn btn-secondary">Back to List</a>
            <a href="{{ path('organizer_events_edit', {'id': event.id}) }}" class="btn btn-create">Edit Event</a>
        </div>
    </div>
    
    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-sm-3"><strong>Description:</strong></div>
                <div class="col-sm-9">{{ event.description ?? 'N/A' }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-3"><strong>Date & Time:</strong></div>
                <div class="col-sm-9">{{ event.eventDate|date('F d, Y H:i') }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-3"><strong>Location:</strong></div>
                <div class="col-sm-9">{{ event.location ?? 'N/A' }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-3"><strong>Price:</strong></div>
                <div class="col-sm-9">₱{{ event.price }}</div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <form method="post" action="{{ path('organizer_events_delete', {'id': event.id}) }}" class="d-inline" onsubmit="return confirm('Delete this event? This cannot be undone.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                    <button class="btn btn-delete" type="submit">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

