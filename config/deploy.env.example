# Railway / production environment variables
# Copy these into Railway → your app service → Variables

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=<random-32+-char-string>
APP_URL=https://<your-service>.up.railway.app
DEFAULT_URI=https://<your-service>.up.railway.app

# Link MySQL plugin — Railway injects DATABASE_URL automatically
# DATABASE_URL=mysql://...

JWT_PASSPHRASE=<strong-secret>
# JWT keys are auto-generated on first boot if missing

# Brevo (production uses HTTPS API, not SMTP port 587)
BREVO_API_KEY=xkeysib-<your-brevo-api-key>
MAILER_FROM_ADDRESS=<verified-sender@example.com>
MAILER_FROM_NAME=Comodo Booking

# Optional: local-style SMTP only for non-prod testing
# BREVO_SMTP_USER=
# BREVO_SMTP_KEY=

GOOGLE_CLIENT_ID=<full-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Google Cloud → Authorized redirect URI:
# https://<your-service>.up.railway.app/connect/google/check

CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1|your-mobile-app-origin)(:[0-9]+)?$

# Railway networking
# - Do NOT set PORT=8000 unless the app listens on 8000
# - Public Networking target port must match deploy logs, e.g. "Nginx binding 0.0.0.0:8080"
# - Railway usually sets PORT=8080 automatically

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
