# Railway → app service → Variables (copy all of these)
# Do NOT commit real secrets to git — set them only in Railway.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=<random-32+-char-string>
APP_URL=https://<your-service>.up.railway.app
DEFAULT_URI=https://<your-service>.up.railway.app
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR

# Link Railway MySQL plugin — Railway usually injects DATABASE_URL automatically
# DATABASE_URL=mysql://...

JWT_PASSPHRASE=<strong-secret>
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# Production mail (HTTPS API — Railway blocks SMTP port 587)
BREVO_API_KEY=xkeysib-<your-brevo-api-key>
MAILER_FROM_ADDRESS=<verified-sender@example.com>
MAILER_FROM_NAME=Comodo Booking

GOOGLE_CLIENT_ID=<full-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Google Cloud → Authorized redirect URI:
# https://<your-service>.up.railway.app/connect/google/check

CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1|your-mobile-app-origin)(:[0-9]+)?$
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Networking: Public port should match deploy logs (usually 8080)
# Do not set PORT=8000 unless nginx listens on 8000
